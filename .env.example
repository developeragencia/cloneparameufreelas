# ===========================================
# meufreelas CLONE - VARIÁVEIS DE AMBIENTE
# ===========================================

# ----- BANCO DE DADOS (Hostinger MySQL) -----
DATABASE_URL="mysql://USUARIO:SENHA@HOST:3306/NOME_BANCO"

# ----- NEXTAUTH -----
NEXTAUTH_URL="https://meufreelas.com.br"
NEXTAUTH_SECRET="gere-uma-chave-secreta-forte-aqui-32-chars-min"

# ----- GOOGLE OAUTH (opcional) -----
GOOGLE_CLIENT_ID="seu-google-client-id"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"

# ----- CLOUDINARY (armazenamento de imagens) -----
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"
CLOUDINARY_UPLOAD_PRESET="freelas-uploads"

# ----- EMAIL (Nodemailer via SMTP) -----
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="noreply@seudominio.com.br"
SMTP_PASS="sua-senha-email"
EMAIL_FROM="meufreelas <noreply@seudominio.com.br>"

# ----- STRIPE (pagamentos) -----
STRIPE_PUBLIC_KEY="pk_live_xxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# ----- CONFIGURAÇÕES DA PLATAFORMA -----
NEXT_PUBLIC_APP_URL="https://meufreelas.com.br"
NEXT_PUBLIC_APP_NAME="meufreelas"
PLATFORM_FEE_PERCENT="10"
MIN_PROJECT_VALUE="50"

# ----- JWT SECRET (para tokens de verificação) -----
JWT_SECRET="outro-segredo-forte-aqui"

# ----- ADMIN -----
ADMIN_EMAIL="admin@seudominio.com.br"
